@model List<GetInTouch>
@{
    ViewData["Title"] = "index";
}
<div class="container">
    <div class="row">
        <div class="col-lg-12 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Blog Table</h4>
                    <p class="card-description">
                        <a asp-controller="contact" asp-action="create">Add contact </a>
                    </p>
                    <div class="table-responsive">
                        <table class="table">
                            
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.PhoneNumber</td>
                                        <td>@item.Name</td>

                                        <td>@item.Email</td>

                                        <td>
                                            <a asp-controller="contact" asp-action="delete" asp-route-id="@item.Id" class="btn btn-outline-danger "><i class="mdi mdi-delete"></i></a>
                                            <a asp-controller="contact" asp-action="update" asp-route-id="@item.Id" class="btn btn-outline-warning"><i class="mdi mdi-table-edit"></i></a>
                                            <a asp-controller="contact" asp-action="detail" asp-route-id="@item.Id" class="btn btn-outline-info"><i class="mdi mdi-account-card-details"></i></a>
                                        </td>
                                    </tr>
                                }


                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>